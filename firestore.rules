rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: product_id
    // Fields:
    //   - id: string (required)
    //   - name: string (required, size < 100)
    //   - price: number (required, positive)
    //   - image: string (required, valid URL)
    //   - category: string (required, size < 50)
    //   - sizes: list (optional, strings)
    //   - isNew: bool (optional)
    //
    // Collection: users/{userId}/cart
    // Document ID: product_id
    // Fields:
    //   - productId: string (required)
    //   - quantity: number (required, positive, max 99)
    //   - size: string (optional)
    //
    // Collection: users/{userId}/wishlist
    // Document ID: product_id
    // Fields:
    //   - productId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "lopezosmedi456@gmail.com");
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    // Validates that a coupon document exists AND is marked active
    function isCouponValid(couponCode) {
      let couponDoc = get(/databases/$(database)/documents/coupons/$(couponCode));
      return couponDoc != null && couponDoc.data.active == true;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'image', 'category']) &&
             data.keys().hasOnly(['id', 'name', 'price', 'image', 'extraImages', 'category', 'brand', 'sizes', 'isNew', 'isOffer', 'isTrending', 'oldPrice', 'stock', 'description', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             isValidUrl(data.image) &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50;
    }

    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'name', 'price', 'image', 'quantity']) &&
             data.keys().hasOnly(['productId', 'name', 'price', 'image', 'quantity', 'size', 'updatedAt']) &&
             data.productId is string &&
             data.name is string &&
             data.price is number && data.price > 0 &&
             isValidUrl(data.image) &&
             data.quantity is number && data.quantity > 0 && data.quantity <= 99;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['productId', 'name', 'price', 'image']) &&
             data.keys().hasOnly(['productId', 'name', 'price', 'image', 'createdAt']) &&
             data.productId is string &&
             data.name is string &&
             data.price is number && data.price > 0 &&
             isValidUrl(data.image);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Products: Publicly readable.
    // Only admin can create/delete/full-update.
    // Authenticated users can ONLY decrement stock (checkout) — never increment,
    // and stock cannot go below 0, preventing inventory abuse.
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
      allow update: if (isAdmin() && isValidProduct(request.resource.data)) ||
                       (isAuthenticated() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
                        request.resource.data.stock < resource.data.stock &&
                        request.resource.data.stock >= 0);
    }

    // User data: Only owner can access.
    // Cart and wishlist enforce schema validation on write.
    match /users/{userId} {
      allow get, write: if isOwner(userId);

      match /cart/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && (
          request.method == 'delete' || isValidCartItem(request.resource.data)
        );
      }

      match /wishlist/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && (
          request.method == 'delete' || isValidWishlistItem(request.resource.data)
        );
      }
    }

    // Admin Panel Collections
    match /user_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin() || (isOwner(userId) && request.resource.data.get('role', 'user') != 'admin');
    }

    match /orders/{orderId} {
      // Security model for shippingCost:
      // Full server-side shipping validation would require reading /settings/site_config in the rule.
      // The total integrity check ensures no hidden price inflation. Admin review catches any
      // fraudulent shippingCost:0 submissions on orders that should have paid shipping.

      allow create: if
        // Auth: admin or the order owner
        (isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid))

        // All monetary fields must be present and valid numbers
        && request.resource.data.subtotal is number && request.resource.data.subtotal > 0
        && request.resource.data.shippingCost is number && request.resource.data.shippingCost >= 0
        && request.resource.data.total is number && request.resource.data.total > 0

        // Total integrity: total == subtotal + shippingCost - discount (null treated as 0)
        && request.resource.data.total == (
             request.resource.data.subtotal
             + request.resource.data.shippingCost
             - (request.resource.data.discountAmount == null ? 0 : request.resource.data.discountAmount)
           )

        // Discount must be null or a non-negative number
        && (request.resource.data.discountAmount == null || request.resource.data.discountAmount >= 0)

        // If discount > 0: coupon must exist AND be active — unless it's an admin (POS manual discount)
        && (request.resource.data.discountAmount == null
            || request.resource.data.discountAmount == 0
            || isAdmin()
            || (request.resource.data.couponCode != null
                && isCouponValid(request.resource.data.couponCode)))

        // Prevent data injection via large text fields
        && (request.resource.data.address == null
            || (request.resource.data.address is string && request.resource.data.address.size() <= 300))
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 100;

      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
