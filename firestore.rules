rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: product_id
    // Fields:
    //   - id: string (required)
    //   - name: string (required, size < 100)
    //   - price: number (required, positive)
    //   - image: string (required, valid URL)
    //   - category: string (required, size < 50)
    //   - sizes: list (optional, strings)
    //   - isNew: bool (optional)
    //
    // Collection: users/{userId}/cart
    // Document ID: product_id
    // Fields:
    //   - productId: string (required)
    //   - quantity: number (required, positive, max 99)
    //   - size: string (optional)
    //
    // Collection: users/{userId}/wishlist
    // Document ID: product_id
    // Fields:
    //   - productId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "lopezosmedi456@gmail.com");
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'image', 'category']) &&
             data.keys().hasOnly(['id', 'name', 'price', 'image', 'extraImages', 'category', 'brand', 'sizes', 'isNew', 'isOffer', 'isTrending', 'oldPrice', 'stock', 'description', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             isValidUrl(data.image) &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50;
    }

    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'name', 'price', 'image', 'quantity']) &&
             data.keys().hasOnly(['productId', 'name', 'price', 'image', 'quantity', 'size', 'updatedAt']) &&
             data.productId is string &&
             data.name is string &&
             data.price is number &&
             isValidUrl(data.image) &&
             data.quantity is number && data.quantity > 0;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['productId', 'name', 'price', 'image']) &&
             data.keys().hasOnly(['productId', 'name', 'price', 'image', 'createdAt']) &&
             data.productId is string &&
             data.name is string &&
             data.price is number &&
             isValidUrl(data.image);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Products: Publicly readable, only admin can fully write, users can deduct stock
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
      allow update: if (isAdmin() && isValidProduct(request.resource.data)) || 
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
    }

    // User data: Only owner can access
    match /users/{userId} {
      allow get, write: if isOwner(userId);

      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Admin Panel Collections
    match /user_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin() || (isOwner(userId) && request.resource.data.get('role', 'user') != 'admin');
    }

    match /orders/{orderId} {
      allow create: if (isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid))
                    && request.resource.data.total == request.resource.data.subtotal + request.resource.data.shippingCost - request.resource.data.discountAmount
                    && request.resource.data.discountAmount >= 0
                    && (request.resource.data.discountAmount == 0 || (request.resource.data.couponCode != null && exists(/databases/$(database)/documents/coupons/$(request.resource.data.couponCode))));
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
