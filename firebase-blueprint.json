{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "isNew": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "image", "category"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in the user's shopping cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "size": { "type": "string" }
      },
      "required": ["productId", "quantity"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "An item in the user's wishlist",
      "type": "object",
      "properties": {
        "productId": { "type": "string" }
      },
      "required": ["productId"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of all available products"
    },
    "/users/{userId}/cart": {
      "schema": "CartItem",
      "description": "User-specific shopping cart items"
    },
    "/users/{userId}/wishlist": {
      "schema": "WishlistItem",
      "description": "User-specific wishlist items"
    }
  }
}
